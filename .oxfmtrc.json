{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"tabWidth": 4,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"endOfLine": "lf",
	"sortImports": {
		"groups": [
			["builtin", "external"],
			["internal", "subpath"],
			["parent", "sibling", "index"],
			"unknown"
		],
		"ignoreCase": false
	}
}
